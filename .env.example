# ── ASR ──────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── TTS ──────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Default: Rachel (professional voice)

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434       # Local Ollama instance
OLLAMA_MODEL=llama3.2:3b                    # or gemma2:4b

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Features ─────────────────────────────────────────────────────────────────
ENABLE_SESSION_RECORDING=false              # Set true to save sessions for replay
LOG_LEVEL=INFO
